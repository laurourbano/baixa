{
  "name": "workdash",
  "version": "1.0.0",
  "description": "Painel de produtividade para fiscais — pareceres, contratos, conferências e mais",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "test:unit": "vitest run",
    "test:integration": "playwright test",
    "test": "npm run test:unit && npm run test:integration",
    "test:watch": "vitest",
    "test:related": "vitest related",
    "bridge": "node bridge/server.js",
    "start": "node bridge/server.js",
    "extract": "node scripts/extrair-atualizadores.js",
    "extract:v4": "node -e \"require('./scripts/extract-excel-v4.js')\"",
    "dev": "http-server -p 8000"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.8",
    "http-server": "^14.1.1",
    "jsdom": "^27.4.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
